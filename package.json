{
  "name": "@enclave/sign-sdk",
  "version": "0.1.0",
  "description": "Post-quantum document signing cryptography for Enclave Sign",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./envelope": {
      "types": "./dist/envelope/index.d.ts",
      "import": "./dist/envelope/index.js"
    },
    "./decrypt": {
      "types": "./dist/decrypt/index.d.ts",
      "import": "./dist/decrypt/index.js"
    },
    "./signing-tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./sender-keys": {
      "types": "./dist/keys/index.d.ts",
      "import": "./dist/keys/index.js"
    },
    "./recipient-signature": {
      "types": "./dist/signature/recipient.d.ts",
      "import": "./dist/signature/recipient.js"
    },
    "./verify-signature": {
      "types": "./dist/signature/verify.d.ts",
      "import": "./dist/signature/verify.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@enclave/pqc-primitives": "file:../../Enclave-Inc/enclave-pqc-primitives"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Enclave-Sign/enclave-sign-sdk"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
